---

---

<section id="hero" class="hero" aria-label="Introduction">
  <div class="hero-bg" aria-hidden="true"></div>
  <div class="hero-logo" aria-hidden="true"></div>
  <div class="hero-content">
    <span class="hero-greeting">Hi, I'm</span>
    <h1 class="hero-name">Hussam Alraggad</h1>
    <p class="hero-role">
      Software Engineer <span class="hero-sep" aria-hidden="true">·</span> AI Researcher
      <span class="hero-sep" aria-hidden="true">·</span> UI/UX Designer
    </p>
    <p class="hero-tagline">
      Researching the intersection of AI and software engineering
      <br />
      while building the interfaces of tomorrow.
    </p>
  </div>
  <a href="#work" class="hero-scroll" aria-label="Scroll to work">
    <span class="hero-scroll-line" aria-hidden="true"></span>
    <span class="hero-scroll-label">Scroll</span>
  </a>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: var(--space-4xl) var(--space-xl);
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 55% at 50% 40%, oklch(0.62 0.18 294 / 0.18) 0%, transparent 70%),
      radial-gradient(ellipse 60% 45% at 30% 55%, oklch(0.7 0.14 70 / 0.08) 0%, transparent 65%),
      radial-gradient(ellipse 50% 40% at 70% 55%, oklch(0.7 0.14 70 / 0.06) 0%, transparent 60%);
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 1;
  }

  .hero-logo {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    z-index: 0;
  }

  .hero-logo::after {
    content: "";
    display: block;
    width: clamp(200px, 40vw, 400px);
    height: clamp(200px, 40vw, 400px);
    background: url("/logo-white.png") center / contain no-repeat;
    opacity: 0.08;
    mask-image: radial-gradient(ellipse 50% 40% at center, black 20%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 50% 40% at center, black 20%, transparent 70%);
  }

  .hero-greeting {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--accent);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    display: block;
    margin-bottom: var(--space-lg);
  }

  .hero-name {
    font-family: var(--font-display);
    font-size: var(--text-5xl);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.03em;
    text-wrap: balance;
    color: var(--ink);
    margin-bottom: var(--space-lg);
  }

  .hero-role {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 500;
    color: var(--muted);
    letter-spacing: -0.01em;
    margin-bottom: var(--space-lg);
  }

  .hero-sep {
    color: var(--primary);
    margin: 0 var(--space-xs);
    font-weight: 600;
  }

  .hero-tagline {
    font-size: var(--text-xl);
    color: var(--ink-subtle);
    line-height: 1.6;
    max-width: 65ch;
    margin: 0 auto;
  }

  .hero-scroll {
    position: absolute;
    bottom: var(--space-3xl);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
    text-decoration: none;
    color: var(--muted);
    transition: color 0.2s var(--ease-out-quart);
  }

  .hero-scroll:hover {
    color: var(--ink);
  }

  .hero-scroll-line {
    display: block;
    width: 1px;
    height: 32px;
    background: currentColor;
    animation: scrollPulse 2.5s var(--ease-out-quart) infinite;
  }

  .hero-scroll-label {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; transform: scaleY(0.6); }
    50% { opacity: 1; transform: scaleY(1); }
  }

  @media (max-width: 640px) {
    .hero-name {
      font-size: clamp(2rem, 10vw, 3rem);
    }

    .hero-role {
      font-size: var(--text-base);
    }

    .hero-tagline {
      font-size: var(--text-base);
    }

    .hero-tagline br {
      display: none;
    }
  }
</style>
