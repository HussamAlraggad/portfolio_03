---

---

<section id="hero" class="hero" aria-label="Introduction">
  <div class="hero-bg" aria-hidden="true"></div>
  <div class="hero-content">
    <span class="hero-greeting">Hi, I'm</span>
    <h1 class="hero-name">Hal Raggað</h1>
    <p class="hero-role">
      Software Engineer <span class="hero-sep" aria-hidden="true">·</span> AI Expert
      <span class="hero-sep" aria-hidden="true">·</span> UI/UX Designer
    </p>
    <p class="hero-tagline">
      I build precise interfaces and intelligent systems
      <br />
      where craft meets capability.
    </p>
  </div>
  <a href="#work" class="hero-scroll" aria-label="Scroll to work">
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
      <path d="M10 3v14M5 12l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </a>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: var(--space-4xl) var(--space-xl);
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 50% 40%, var(--primary-glow) 0%, transparent 70%),
      radial-gradient(ellipse 50% 40% at 70% 60%, oklch(0.7 0.14 70 / 0.04) 0%, transparent 60%);
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 1;
  }

  .hero-greeting {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--accent);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    display: block;
    margin-bottom: var(--space-lg);
  }

  .hero-name {
    font-family: var(--font-display);
    font-size: var(--text-5xl);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.03em;
    text-wrap: balance;
    color: var(--ink);
    margin-bottom: var(--space-lg);
  }

  .hero-role {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 500;
    color: var(--muted);
    letter-spacing: -0.01em;
    margin-bottom: var(--space-lg);
  }

  .hero-sep {
    color: var(--primary);
    margin: 0 var(--space-xs);
    font-weight: 600;
  }

  .hero-tagline {
    font-size: var(--text-xl);
    color: var(--ink-subtle);
    line-height: 1.6;
    max-width: 65ch;
    margin: 0 auto;
  }

  .hero-scroll {
    position: absolute;
    bottom: var(--space-3xl);
    color: var(--muted);
    transition: color 0.2s var(--ease-out-quart), transform 0.2s var(--ease-out-quart);
    animation: float 3s var(--ease-out-quart) infinite;
  }

  .hero-scroll:hover {
    color: var(--ink);
    transform: translateY(2px);
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }

  @media (max-width: 640px) {
    .hero-name {
      font-size: clamp(2rem, 10vw, 3rem);
    }

    .hero-role {
      font-size: var(--text-base);
    }

    .hero-tagline {
      font-size: var(--text-base);
    }

    .hero-tagline br {
      display: none;
    }
  }
</style>
