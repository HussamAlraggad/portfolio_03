---
interface Project {
  title: string;
  year: string;
  description: string;
  outcome: string;
  tags?: string[];
}

const projects: Project[] = [
  {
    title: "mini_wiki_2.0",
    year: "2026",
    description: "An intelligent co-researcher built in Go — an AI-powered research assistant that helps explore and synthesize information efficiently.",
    outcome: "Go-based AI research tool",
    tags: ["Go", "AI", "Research"],
  },
  {
    title: "mini_wiki_3.0",
    year: "2026",
    description: "The next iteration of the intelligent co-researcher — evolved with improved architecture and deeper research capabilities. The evolved version of mini_wiki_2.0.",
    outcome: "1 star · Go AI research tool v2",
    tags: ["Go", "AI", "Research"],
  },
  {
    title: "fashion_store_v1",
    year: "2026",
    description: "A luxury fur fashion e-commerce prototype built with Next.js 14, TypeScript, and Tailwind CSS. Features age-gated entry, 30 products across 6 categories, multi-step checkout, admin dashboard, and a complete luxury design system.",
    outcome: "Full e-commerce prototype with admin panel",
    tags: ["Next.js", "TypeScript", "Tailwind", "E-Commerce"],
  },
  {
    title: "os_geeks_hub_02",
    year: "2026",
    description: "An OS recommendation and discovery hub — helps tech enthusiasts find the right operating system by providing curated information, documentation links, and download sources. Built with Astro.",
    outcome: "Live at os-geeks-hub.netlify.app",
    tags: ["Astro", "TypeScript", "Docs"],
  },
  {
    title: "school_lms_template",
    year: "2026",
    description: "A bilingual (Arabic/English) school LMS platform. Features homework management, interactive quizzes, educational materials, news/announcements, and exam schedules. Built with Next.js 16, PocketBase, and TanStack Query.",
    outcome: "Full bilingual LMS platform",
    tags: ["Next.js", "PocketBase", "TypeScript", "Education"],
  },
  {
    title: "Glassdoor RAG Pipeline",
    year: "2026",
    description: "An AI-powered Software Requirements Engineering pipeline. Ingests ~10M Glassdoor reviews via FAISS vector search, then uses LangChain + LLaMA 3 to generate complete IEEE 830 SRS documents. CUDA-accelerated embedding and retrieval.",
    outcome: "Generates structured SRS from raw review data",
    tags: ["Python", "LangChain", "FAISS", "LLM", "CUDA"],
  },
  {
    title: "fruit_basket_3",
    year: "2026",
    description: "A JavaScript web application deployed on GitHub Pages.",
    outcome: "Live on GitHub Pages",
    tags: ["JavaScript", "HTML", "CSS"],
  },
  {
    title: "42AmmanJourney",
    year: "2025–2026",
    description: "A collection of C programming projects from the 42 Amman curriculum — including Libft, Printf, and other systems-level implementations from the Piscine and Common Core.",
    outcome: "1 star · 42 curriculum projects",
    tags: ["C", "Systems", "Algorithms"],
  },
];
---

<section id="work" class="section projects">
  <div class="projects-inner">
    <div class="section-header">
      <span class="section-label">Selected work</span>
      <h2 class="section-title">Projects</h2>
      <p class="section-desc">
        Open-source projects — from AI research tools and LLM pipelines to full-stack apps and systems programming.
      </p>
    </div>
    <div class="projects-grid">
      {projects.map((project, i) => (
        <article class="project-card" style="transition-delay: {i * 0.08}s">
          <div class="card-top">
            <span class="card-year">{project.year}</span>
            <span class="card-accent" aria-hidden="true"></span>
          </div>
          <h3 class="card-title">{project.title}</h3>
          <p class="card-desc">{project.description}</p>
          <p class="card-outcome">{project.outcome}</p>
          {project.tags && (
            <ul class="card-tags" role="list" aria-label="Technologies used">
              {project.tags.map((tag) => (
                <li class="card-tag">{tag}</li>
              ))}
            </ul>
          )}
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .projects {
    background: var(--surface);
  }

  .projects-inner {
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 var(--space-xl);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 320px), 1fr));
    gap: var(--space-xl);
  }

  .project-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    padding: var(--space-xl);
    background: var(--bg);
    border: 1px solid var(--border-subtle);
    border-radius: 8px;
    transition: border-color 0.3s var(--ease-out-quart), box-shadow 0.3s var(--ease-out-quart), transform 0.3s var(--ease-out-quart);
  }

  .project-card:hover {
    border-color: var(--primary-dim);
    box-shadow: 0 0 20px var(--primary-glow);
    transform: translateY(-4px);
  }

  .card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-sm);
  }

  .card-year {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--muted);
  }

  .card-accent {
    display: block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--primary);
  }

  .card-title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.02em;
    text-wrap: balance;
  }

  .card-desc {
    font-size: var(--text-sm);
    color: var(--ink-subtle);
    line-height: 1.65;
  }

  .card-outcome {
    font-size: var(--text-sm);
    color: var(--accent);
    font-weight: 500;
    margin-top: auto;
    padding-top: var(--space-md);
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    list-style: none;
  }

  .card-tag {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--muted);
    background: var(--tag-bg);
    padding: 0.1875rem 0.5rem;
    border-radius: 4px;
  }
</style>
